{
  "name": "zenith-cms",
  "version": "0.2.0",
  "description": "Zenith CMS — The Industrial Operational Platform for High-Fidelity Digital Ecosystems.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r dev",
    "start": "tsx server.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check-deps": "depcruise packages --config .dependency-cruiser.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express-mongo-sanitize": "^2.1.2",
    "@types/node": "^20.19.41",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "bcrypt"
    ]
  }
}
