{
  "name": "zenith-cms",
  "version": "1.0.0-beta",
  "description": "Zenith CMS — The Industrial Operational Platform for High-Fidelity Digital Ecosystems.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r --parallel dev",
    "start": "tsx server.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:all": "node e2e/run-all.js",
    "test:e2e:ui": "playwright test --ui",
    "lint": "pnpm -r lint",
    "seed": "tsx packages/core/src/database/seed.ts",
    "check-deps": "depcruise packages --config .dependency-cruiser.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.60.0",
    "@types/express-mongo-sanitize": "^2.1.2",
    "@types/node": "^20.19.41",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "license-checker": "25.0.1",
    "playwright": "1.60.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "zod": "^3.25.76",
      "drizzle-orm": "^0.45.2",
      "tar": ">=7.5.11",
      "js-cookie": ">=3.0.7",
      "esbuild": ">=0.28.1",
      "ws": ">=8.20.1",
      "qs": ">=6.15.2"
    },
    "onlyBuiltDependencies": [
      "bcrypt",
      "core-js",
      "esbuild",
      "leveldown",
      "mongodb-memory-server"
    ]
  }
}
