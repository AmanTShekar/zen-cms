#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🪐 Zenith Commit Gatekeeper: Verifying Conventional Commit structure..."

# Run commitlint to check formatting
npx commitlint --edit "$1" || {
  echo "❌ Error: Commit message does not match Conventional Commits specifications!"
  echo "💡 Examples of valid messages:"
  echo "   feat(core): add next-gen Strapi-to-Zenith translation engine"
  echo "   fix(admin): resolve card sizing styling on hover"
  echo "   docs(readme): update developer playbook instructions"
  exit 1
}

echo "✅ Success: Commit message approved!"
exit 0
