#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🪐 Zenith Git Gatekeeper: Verifying codebase quality..."

# 1. Run Prettier to ensure strict format compliance
echo "→ Running Prettier check..."
npx prettier --check "packages/**/*.{ts,tsx,js,json,css}" || {
  echo "❌ Error: Code formatting does not match Prettier standards!"
  echo "💡 Tip: Run 'npx prettier --write .' to fix formatting errors."
  exit 1
}

# 2. Run ESLint to prevent compiler errors and syntax regressions
echo "→ Running ESLint diagnostics..."
npx eslint . || {
  echo "❌ Error: ESLint diagnostics failed!"
  exit 1
}

# 3. Run TypeScript type compilation check
echo "→ Running TypeScript compiler check..."
pnpm run build || {
  echo "❌ Error: TypeScript compilation failed!"
  exit 1
}

# 4. Run test suite
echo "→ Running test suite..."
pnpm test || {
  echo "❌ Error: Tests failed!"
  exit 1
}

echo "✅ Success: Code is pristine, builds cleanly, and passes all tests! Ready to commit."
exit 0
