{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@zenith-open/zenithcms-types": ["./packages/types/src/index.ts"],
      "@zenith-open/zenithcms-*": ["./packages/*/src"]
    },
    "types": []
  },
  "include": [
    "packages/core/src/**/*.ts",
    "packages/db-mongodb/src/**/*.ts",
    "packages/db-postgres/src/**/*.ts",
    "packages/types/src/**/*.ts",
    "packages/cli/src/**/*.ts",
    "packages/sdk/src/**/*.ts",
    "packages/create-zenithcms-app/src/**/*.ts",
    "server.ts",
    "cms.config.ts"
  ],
  "exclude": ["node_modules", "**/dist", "**/*.test.ts", "internal"]
}
