# Zenith Storefront — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to GitHub — it's already in .gitignore.

# Your Zenith CMS API URL (where the core engine is running)
VITE_CMS_URL=http://localhost:3000

# Your API Key (from Zenith Admin Dashboard → Settings → API Keys)
VITE_CMS_API_KEY=

# Your Site ID (from Zenith Admin Dashboard → Settings → Sites)
VITE_CMS_SITE_ID=