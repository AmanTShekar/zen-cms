{
  "mcpServers": {
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db", "packages/core/zenith.db"],
      "disabled": false,
      "alwaysAllow": []
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://payload:payload@localhost:5432/zenith"
      ],
      "disabled": true,
      "alwaysAllow": []
    },
    "mongodb": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-mongodb", "mongodb://localhost:27017/zenith"],
      "disabled": true,
      "alwaysAllow": []
    }
  }
}
