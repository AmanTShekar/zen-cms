{
  "name": "@zenithcms/core",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Zenith CMS — headless engine with REST, GraphQL, and AI tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "schema:export": "tsx src/tools/export-schema.ts"
  },
  "bin": {
    "zenithcms": "dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-s3": "3.1048.0",
    "@zenithcms/db-mongodb": "workspace:*",
    "@zenithcms/db-postgres": "workspace:*",
    "@zenithcms/types": "workspace:*",
    "ajv": "^8.20.0",
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.5.0",
    "commander": "^12.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.0",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "resend": "^3.5.0",
    "sharp": "0.34.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.0",
    "@types/diff": "^8.0.0",
    "@types/express": "^4.17.0",
    "@types/express-mongo-sanitize": "^2.1.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
