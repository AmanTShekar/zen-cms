{
  "name": "@zenith-open/zenithcms-core",
  "version": "1.0.0-beta",
  "publishConfig": {
    "access": "public"
  },
  "description": "Zenith CMS — headless engine with REST, GraphQL, and AI tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:types": "tsx src/tools/generate-types.ts",
    "generate:drizzle": "tsx src/tools/sync-drizzle.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "schema:export": "tsx src/tools/export-schema.ts",
    "schema:sync": "tsx src/tools/schema-sync.ts",
    "schema:drizzle": "tsx src/tools/export-drizzle.ts",
    "migration:run": "tsx scripts/migrate.ts",
    "migration:tenant-scope": "tsx scripts/migrate-tenant-scope.ts",
    "migration:generate": "tsx scripts/generate-migration.ts",
    "migration:rollback": "tsx scripts/rollback-migration.ts"
  },
  "bin": {
    "zenithcms": "dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-s3": "3.1048.0",
    "@aws-sdk/lib-storage": "3.1072.0",
    "@node-saml/passport-saml": "5.1.0",
    "@opentelemetry/api": "1.8.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.50.0",
    "@opentelemetry/instrumentation": "0.218.0",
    "@opentelemetry/instrumentation-express": "0.66.0",
    "@opentelemetry/instrumentation-http": "0.218.0",
    "@opentelemetry/resources": "^1.23.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "^1.23.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/semantic-conventions": "^1.23.0",
    "@sentry/node": "^10.58.0",
    "@sentry/profiling-node": "10.58.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "8.0.1",
    "@zenith-open/zenithcms-db-mongodb": "workspace:*",
    "@zenith-open/zenithcms-db-postgres": "workspace:*",
    "@zenith-open/zenithcms-types": "workspace:*",
    "JSONStream": "1.3.5",
    "ajv": "^8.20.0",
    "bcrypt": "^5.1.0",
    "chokidar": "^3.5.3",
    "cloudinary": "^2.5.0",
    "commander": "^12.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.0",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.0",
    "graphql-query-complexity": "1.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.0",
    "meilisearch": "0.58.0",
    "mongoose": "^8.4.0",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "9.0.1",
    "otplib": "13.4.0",
    "passport": "0.7.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "15.1.3",
    "qrcode": "1.5.4",
    "redis": "^4.7.1",
    "redlock": "5.0.0-beta.2",
    "resend": "^3.5.0",
    "sanitize-html": "2.17.5",
    "sharp": "0.34.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.0",
    "@types/diff": "^8.0.0",
    "@types/express": "^4.17.0",
    "@types/express-mongo-sanitize": "^2.1.2",
    "@types/jsonstream": "0.8.33",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport": "1.0.17",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/qrcode": "1.5.6",
    "@types/sanitize-html": "2.16.1",
    "@types/supertest": "7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "3.2.6",
    "drizzle-kit": "0.31.10",
    "mongodb-memory-server": "11.2.0",
    "supertest": "7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
