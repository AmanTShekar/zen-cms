# Admin Client Environment
# Copy to .env.local and fill in values

# URL of your frontend storefront (required for live preview)
VITE_STOREFRONT_URL=http://localhost:5173

# API URL — defaults to '/api/v1' (Vite proxy in dev, same-origin in production)
# Only set this if the API is on a completely different domain
# VITE_API_URL=http://localhost:3000/api/v1