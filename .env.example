# 🪐 Zenith CMS — Environment Configuration Template
# Copy this file to '.env' and populate with your local/production credentials.

# ──────────────────────────────────────────────────────────────────────────────
# 1. SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
NODE_ENV=development

# Trust reverse proxy headers (e.g. cloudflare, nginx)
# Set to 'true', '1', or a comma-separated list of IP addresses.
TRUST_PROXY=false

# CORS Allowed Origins (Comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# 2. persistence / database configuration
# ──────────────────────────────────────────────────────────────────────────────
# Options: 'mongodb' or 'postgres'
DATABASE_TYPE=mongodb

# MongoDB Connection String (Required if DATABASE_TYPE=mongodb)
MONGODB_URI=mongodb://localhost:27017/zenith

# PostgreSQL Connection String (Required if DATABASE_TYPE=postgres)
# POSTGRES_URI or DATABASE_URL can be used.
POSTGRES_URI=postgres://postgres:postgres@localhost:5432/zenith
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zenith

# ──────────────────────────────────────────────────────────────────────────────
# 3. distributed caching & worker engine
# ──────────────────────────────────────────────────────────────────────────────
# Redis connection URL (Enables distributed neural caching, rate limiting, and webhook queue)
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────────
# 4. CRYPTOGRAPHIC & SESSION SECURITY
# ──────────────────────────────────────────────────────────────────────────────
# JWT secrets (Must be strong random strings in production)
JWT_SECRET=super_secret_jwt_sign_key_minimum_32_characters
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_minimum_32_characters

# CSRF & Live Preview authentication secret
PREVIEW_SECRET=zenith_preview_secret_v1

# ──────────────────────────────────────────────────────────────────────────────
# 5. STORAGE & MEDIA SERVICE
# ──────────────────────────────────────────────────────────────────────────────
# Options: 'local' or 's3'
STORAGE_PROVIDER=local

# AWS S3 / Compatible storage endpoint (Required if STORAGE_PROVIDER=s3)
S3_REGION=us-east-1
S3_BUCKET=zenith-media-bucket
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_PUBLIC_URL=https://cdn.zenith.local

# Cloudinary Integration (Alternative media hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# 6. EXTERNAL integrations & api keys
# ──────────────────────────────────────────────────────────────────────────────
# Resend Email Integration
RESEND_API_KEY=
EMAIL_FROM=Zenith CMS <noreply@zenith.local>

# Frontend Admin URL (Used in email template redirects)
ADMIN_URL=http://localhost:5173

# Stripe Payment / Billing Gateway
STRIPE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# 7. AI ENGINE (NEURAL BRIDGE Integration)
# ──────────────────────────────────────────────────────────────────────────────
# Provide at least one key below to enable AI-powered layout and content generation.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# 8. LICENSING & ENTERPRISE EDITION
# ──────────────────────────────────────────────────────────────────────────────
# Zenith commercial license key for enterprise features
ZENITH_LICENSE_KEY=
IS_EE=false
