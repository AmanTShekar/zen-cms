# ------------------------------------------------------------------------------
# ZENITH CMS - ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# ── 1. Core Services ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database Connection (MongoDB or PostgreSQL)
DATABASE_URL=mongodb://localhost:27017/zenith
# DATABASE_URL=postgresql://zenith:zenith_password@localhost:5432/zenith

# Redis (Optional but recommended for Webhooks, Rate Limiting, and Pub/Sub)
REDIS_URL=redis://localhost:6379

# ── 2. Security & Authentication ──────────────────────────────────────────────
# Critical: Must be a long, randomly generated secret in production
JWT_SECRET=super_secret_dev_key_replace_me_in_production
SESSION_EXPIRY=1d

# Admin Auth Rate Limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# API Rate Limits
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100

# ── 3. Storage (S3 Compatible) ────────────────────────────────────────────────
# Leave blank to use local file storage in /config/media
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── 4. Webhooks ───────────────────────────────────────────────────────────────
# Max retries and delays for webhook delivery failures
WEBHOOK_MAX_RETRIES=4
WEBHOOK_RETRY_DELAYS=180000,300000,900000,3600000
WEBHOOK_TIMEOUT_MS=5000

# ── 5. Playwright & E2E Testing (Optional) ────────────────────────────────────
TEST_USER_EMAIL=e2e_admin@zenithcms.com
TEST_USER_PASSWORD=Password123!
