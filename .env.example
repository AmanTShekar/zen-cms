MONGODB_URI=mongodb://localhost:27017/zenith
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=another_long_random_string_different_from_jwt_secret
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Initial Admin (used only on first run via scripts/setup.ts)
INITIAL_ADMIN_EMAIL=admin@zenith.com
INITIAL_ADMIN_PASSWORD=Zenith2024!

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Admin UI URL (for password reset emails)
ADMIN_URL=http://localhost:5173

# Live Preview JWT secret
PREVIEW_SECRET=change_this_to_a_preview_secret

# Cloudinary (optional — media uploads return 503 if missing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Integration (optional — AI features disabled if missing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Email (optional — logs to console in development)
RESEND_API_KEY=

# Webhook signing secret (used for outgoing webhook HMAC)
WEBHOOK_SECRET=change_this_to_a_webhook_secret
