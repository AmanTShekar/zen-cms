# 📦 Zenith Package Manager Rules (.npmrc)
# Enforces exact version pinning, local workspace resolving, and lockfile speedups.

# Force exact version saving to prevent dependency drifts (caret/tilde bypass)
save-exact=true

# Link workspace packages together immediately so local code changes sync instantly
link-workspace-packages=true

# Resolve dependencies inside the workspace first, avoiding unnecessary NPM registry fetches
prefer-workspace-packages=true

# Prevent pnpm from modifying dependencies dynamically on dev builds
strict-peer-dependencies=true

# Optimise concurrency for monorepos
child-concurrency=10
only-built-dependencies[]=bcrypt

